from pathlib import Path
from ase.io import read, write
from ase.mep import NEB

base = Path(r"D:\shuoshi\essay\11\neb\clean").resolve()

initial = read(base / "00", format="abacus")
final = read(base  / "08", format="abacus")

n_images = 7  # 总 image 数：初态 + 中间 image + 末态

if len(initial) != len(final):
    raise ValueError("初态和末态原子数不一致")

if initial.get_chemical_symbols() != final.get_chemical_symbols():
    raise ValueError("初态和末态原子顺序不一致")

images = [initial]

for _ in range(n_images - 2):
    images.append(initial.copy())

images.append(final)

neb = NEB(images)
neb.interpolate(method="idpp")

write(base / "init_neb_chain.traj", images)

print("已生成 init_neb_chain.traj")
