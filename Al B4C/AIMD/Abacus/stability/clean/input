INPUT_PARAMETERS

# ===== Basic settings =====
suffix Al_B4C_slab_AIMD_600K
ntype 3
calculation md
basis_type lcao

# ===== File paths =====
pseudo_dir ./
orbital_dir ./

# ===== Accuracy / SCF =====
ecutwfc 100
scf_thr 1e-7
scf_nmax 80

# Explicit solver for LCAO
ks_solver genelpa

# Gamma-only acceleration for large slab AIMD
gamma_only 1

# Smearing
smearing_method gaussian
smearing_sigma 0.01

# Charge mixing
mixing_beta 0.3

# ===== Slab settings =====
symmetry 0

# Dipole correction for slab
efield_flag 1
dip_cor_flag 1
efield_dir 2
efield_pos_max 0.85
efield_pos_dec 0.1
efield_amp 0.0

# ===== AIMD settings =====
md_type nvt
md_thermostat nhc

# 600 K constant-temperature AIMD
md_nstep 10000
md_dt 1.0
md_tfirst 600
md_tlast 600

md_restart 0
md_dumpfreq 100
md_restartfreq 1000
md_seed -1

# This parameter mainly matters for velocity rescaling-type thermostats
md_tolerance 50

# ===== Output control =====
out_chg -1
out_pot 0
out_dos 0
out_band 0
