#ABACUS-NEB计算不需要传统输入文件，先将初态末态scf优化好，利用ase-script里的traj生成脚本生成初猜轨迹，yaml文件会自动生成INPUTS
 #!!! 记得改赝势和轨道地址
calculation:
  type: neb
  init_chain: inputs/init_neb_chain.traj
  climb: true
  fmax: 0.80
  k: 0.1
  algorism: improvedtangent
  parallel: true
  optimizer: FIRE
  max_steps: 1
  trajectory: neb.traj

calculator:
  name: abacus
  abacus:
    command: abacus
    mpi: 40
    omp: 1
    directory: run_neb
    kpts: [3, 1, 3]
    parameters:
        calculation: scf
        ecutwfc: 100
        basis_type: lcao
        ks_solver: genelpa
        vdw_method: d3_bj
        nspin: 2
        symmetry: 1
        scf_thr: 1e-04
        scf_nmax: 100
        smearing_method: mp
        smearing_sigma: 0.002
        mixing_type: broyden
        cal_force: 1
        cal_stress: 1
        out_stru: 1
        efield_flag: 1
        dip_cor_flag: 1
        efield_dir: 1
        efield_pos_max: 0.8
        efield_pos_dec: 0.1
        efield_amp: 0.0
        pseudo_dir: /data/home/a2377362766/pp
        orbital_dir: /data/home/a2377362766/orb
        pseudopotentials:
           H: H.upf
           Au: Au.upf
        basissets:
           H: H.orb
           Au: Au.orb   
           
