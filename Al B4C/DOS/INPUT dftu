#DFT＋U通用INPUT，不同的元素改改U和赝势，轨道就行
INPUT_PARAMETERS
suffix              Al_B4C_Sm_DOS_DFTU
calculation         scf
esolver_type        ksdft
basis_type          lcao
ks_solver           genelpa

stru_file           STRU
kpoint_file         KPT
pseudo_dir          /phadcloud/home/phadcloud02yj16717/1/pseu
orbital_dir         /phadcloud/home/phadcloud02yj16717/1/orb

symmetry            0
nspin               2
ecutwfc             100
scf_thr             1.0e-5
scf_nmax            200

# DFT+U for Eu 4f electrons.
dft_plus_u          1
orbital_corr        -1 -1 -1 3
hubbard_u           0.0 0.0 0.0 5.4

smearing_method     gaussian
smearing_sigma      0.01
mixing_type         broyden
mixing_beta         0.15
mixing_ndim         8

out_chg             1
out_dos             2
dos_emin_ev         -20
dos_emax_ev         20
dos_edelta_ev       0.01
