INPUT_PARAMETERS
suffix              Al_B4C_Eu_DOS_DFTU
calculation         scf
esolver_type        ksdft
basis_type          lcao
ks_solver           genelpa

stru_file           STRU
kpoint_file         KPT
pseudo_dir          ./
orbital_dir         ./

symmetry            0
nspin               2
ecutwfc             100
scf_thr             1.0e-5
scf_nmax            300

# DFT+U for Eu 4f electrons.
# Eu.upf from ABACUS Dojo-NC-SR_La-Series treats Eu 4f as valence-like correlated states.
# Element order assumed in STRU: B C Al Eu. If STRU order is different, reorder orbital_corr/hubbard_u accordingly.
dft_plus_u          1
orbital_corr        -1 -1 -1 3
hubbard_u           0.0 0.0 0.0 6.0

smearing_method     gaussian
smearing_sigma      0.01
mixing_type         broyden
mixing_beta         0.15
mixing_ndim         8

out_chg             1
out_dos             1
dos_emin_ev         -20
dos_emax_ev         20
dos_edelta_ev       0.01
